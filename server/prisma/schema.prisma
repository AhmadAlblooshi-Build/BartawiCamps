generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
model audit_logs {
  id            BigInt   @default(autoincrement())
  tenant_id     String?  @db.Uuid
  user_id       String?  @db.Uuid
  action        String   @db.VarChar(100)
  resource_type String?  @db.VarChar(100)
  resource_id   String?  @db.Uuid
  old_values    Json?
  new_values    Json?
  ip_address    String?  @db.Inet
  user_agent    String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  tenants       tenants? @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([id, created_at])
  @@index([resource_type, resource_id], map: "idx_audit_resource")
}

model bed_occupancy {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bed_space_id       String      @db.Uuid
  room_id            String      @db.Uuid
  individual_id      String      @db.Uuid
  check_in_date      DateTime?   @db.Date
  check_out_date     DateTime?   @db.Date
  reason_for_leaving String?
  is_current         Boolean?    @default(true)
  created_by         String?     @db.Uuid
  created_at         DateTime?   @default(now()) @db.Timestamptz(6)
  bed_spaces         bed_spaces  @relation(fields: [bed_space_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users?      @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  individuals        individuals @relation(fields: [individual_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms              rooms       @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model bed_spaces {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id       String          @db.Uuid
  bed_number    Int
  status        String          @default("vacant") @db.VarChar(20)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  bed_occupancy bed_occupancy[]
  rooms         rooms           @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([room_id, bed_number])
}

model blocks {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  building_id  String    @db.Uuid
  camp_id      String    @db.Uuid
  code         String    @db.VarChar(20)
  floor_label  String    @default("Ground") @db.VarChar(20)
  floor_number Int       @default(0)
  room_count   Int       @default(0)
  is_active    Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  buildings    buildings @relation(fields: [building_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  camps        camps     @relation(fields: [camp_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rooms        rooms[]

  @@unique([camp_id, code])
}

model buildings {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  camp_id           String            @db.Uuid
  code              String            @db.VarChar(20)
  name              String            @db.VarChar(100)
  floor_count       Int               @default(2)
  ground_block_code String?           @db.VarChar(10)
  upper_block_code  String?           @db.VarChar(10)
  map_x             Decimal?          @db.Decimal(10, 2)
  map_y             Decimal?          @db.Decimal(10, 2)
  map_width         Decimal?          @db.Decimal(10, 2)
  map_height        Decimal?          @db.Decimal(10, 2)
  map_rotation      Decimal?          @default(0) @db.Decimal(5, 2)
  map_shape_type    String?           @default("rect") @db.VarChar(20)
  map_shape_points  Json?
  label_offset_x    Decimal?          @default(0) @db.Decimal(10, 2)
  label_offset_y    Decimal?          @default(-12) @db.Decimal(10, 2)
  is_active         Boolean?          @default(true)
  notes             String?
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?         @default(now()) @db.Timestamptz(6)
  blocks            blocks[]
  camps             camps             @relation(fields: [camp_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  complaints        complaints[]
  qr_codes          qr_codes[]
  rooms             rooms[]
  sensor_devices    sensor_devices[]
  sensor_readings   sensor_readings[]

  @@unique([camp_id, code])
}

model camps {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String                 @db.Uuid
  name                 String                 @db.VarChar(100)
  code                 String                 @db.VarChar(20)
  address              String?
  city                 String?                @default("Dubai") @db.VarChar(100)
  country              String?                @default("UAE") @db.VarChar(100)
  total_rooms          Int                    @default(0)
  leasable_rooms       Int                    @default(0)
  map_canvas_width     Decimal?               @default(1400) @db.Decimal(10, 2)
  map_canvas_height    Decimal?               @default(900) @db.Decimal(10, 2)
  map_configured       Boolean?               @default(false)
  map_configured_at    DateTime?              @db.Timestamptz(6)
  floorplan_url        String?
  floorplan_width      Int?
  floorplan_height     Int?
  is_active            Boolean?               @default(true)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  balance_writeoffs    balance_writeoffs[]
  blocks               blocks[]
  buildings            buildings[]
  tenants              tenants                @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  complaints           complaints[]
  contract_alerts      contract_alerts[]
  contracts            contracts[]
  expenses             expenses[]
  maintenance_requests maintenance_requests[]
  map_layouts          map_layouts[]
  monthly_records      monthly_records[]
  payment_schedules    payment_schedules[]
  payments             payments[]
  qr_codes             qr_codes[]
  room_occupancy       room_occupancy[]
  rooms                rooms[]
  security_deposits    security_deposits[]
  sensor_devices       sensor_devices[]
  sensor_readings      sensor_readings[]

  @@unique([tenant_id, code])
}

model companies {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String              @db.Uuid
  name              String              @db.VarChar(255)
  name_normalized   String?             @db.VarChar(255)
  trade_license     String?             @db.VarChar(100)
  contact_person    String?             @db.VarChar(255)
  contact_phone     String?             @db.VarChar(50)
  contact_email     String?             @db.VarChar(255)
  address           String?
  industry          String?             @db.VarChar(100)
  is_active         Boolean?            @default(true)
  notes             String?
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  related_entity_id String?             @db.Uuid
  entity_group_name String?             @db.VarChar(255)
  balance_writeoffs balance_writeoffs[]
  companies         companies?          @relation("companiesTocompanies", fields: [related_entity_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_companies   companies[]         @relation("companiesTocompanies")
  tenants           tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  contracts         contracts[]
  monthly_records   monthly_records[]
  room_occupancy    room_occupancy[]
  security_deposits security_deposits[]

  @@unique([tenant_id, name_normalized], map: "idx_companies_tenant_name_norm")
  @@index([entity_group_name], map: "idx_companies_group")
  @@index([related_entity_id], map: "idx_companies_related")
}

model complaint_categories {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String                 @db.Uuid
  name                 String                 @db.VarChar(100)
  priority_default     String?                @default("medium") @db.VarChar(20)
  is_active            Boolean?               @default(true)
  default_team_id      String?                @db.Uuid
  teams                teams?                 @relation(fields: [default_team_id], references: [id], onUpdate: NoAction)
  tenants              tenants                @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  complaints           complaints[]
  maintenance_requests maintenance_requests[]
}

model complaint_updates {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaint_id String     @db.Uuid
  user_id      String?    @db.Uuid
  old_status   String?    @db.VarChar(30)
  new_status   String?    @db.VarChar(30)
  note         String?
  created_at   DateTime?  @default(now()) @db.Timestamptz(6)
  complaints   complaints @relation(fields: [complaint_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model complaints {
  id                                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  complaint_ref                            String                @unique @db.VarChar(30)
  camp_id                                  String                @db.Uuid
  room_id                                  String?               @db.Uuid
  building_id                              String?               @db.Uuid
  category_id                              String?               @db.Uuid
  title                                    String                @db.VarChar(255)
  description                              String?
  status                                   String                @default("open") @db.VarChar(30)
  priority                                 String                @default("medium") @db.VarChar(20)
  reported_by_user                         String?               @db.Uuid
  reported_by_name                         String?               @db.VarChar(255)
  reported_by_room                         String?               @db.VarChar(20)
  reported_via                             String?               @default("staff") @db.VarChar(30)
  assigned_to                              String?               @db.Uuid
  resolved_at                              DateTime?             @db.Timestamptz(6)
  resolved_by                              String?               @db.Uuid
  resolution_notes                         String?
  closed_at                                DateTime?             @db.Timestamptz(6)
  image_urls                               Json?                 @default("[]")
  created_at                               DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime?             @default(now()) @db.Timestamptz(6)
  complaint_updates                        complaint_updates[]
  users_complaints_assigned_toTousers      users?                @relation("complaints_assigned_toTousers", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  buildings                                buildings?            @relation(fields: [building_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  camps                                    camps                 @relation(fields: [camp_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  complaint_categories                     complaint_categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_complaints_reported_by_userTousers users?                @relation("complaints_reported_by_userTousers", fields: [reported_by_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_complaints_resolved_byTousers      users?                @relation("complaints_resolved_byTousers", fields: [resolved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms                                    rooms?                @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([camp_id], map: "idx_complaints_camp")
  @@index([status], map: "idx_complaints_status")
}

model contract_alerts {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_id       String    @db.Uuid
  camp_id           String    @db.Uuid
  alert_type        String    @db.VarChar(50)
  days_until_expiry Int?
  is_acknowledged   Boolean?  @default(false)
  acknowledged_by   String?   @db.Uuid
  acknowledged_at   DateTime? @db.Timestamptz(6)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  users             users?    @relation(fields: [acknowledged_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  camps             camps     @relation(fields: [camp_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contracts         contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model contracts {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  camp_id             String              @db.Uuid
  room_id             String              @db.Uuid
  company_id          String?             @db.Uuid
  contract_type       String              @default("monthly") @db.VarChar(30)
  monthly_rent        Decimal             @default(0) @db.Decimal(10, 2)
  start_date          DateTime?           @db.Date
  end_date            DateTime?           @db.Date
  auto_renew          Boolean?            @default(false)
  renewal_notice_days Int?                @default(60)
  status              String?             @default("active") @db.VarChar(30)
  ejari_number        String?             @db.VarChar(100)
  notes               String?
  created_by          String?             @db.Uuid
  created_at          DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?           @default(now()) @db.Timestamptz(6)
  individual_id       String?             @db.Uuid
  contract_alerts     contract_alerts[]
  contract_notes      contract_notes[]
  contract_renewals   contract_renewals[]
  camps               camps               @relation(fields: [camp_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies           companies?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  individuals         individuals?        @relation(fields: [individual_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms               rooms               @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment_schedules   payment_schedules[]
  room_occupancy      room_occupancy[]
  security_deposits   security_deposits[]

  @@index([room_id], map: "idx_contracts_room")
}

model expense_categories {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String     @db.Uuid
  name        String     @db.VarChar(100)
  description String?
  is_active   Boolean?   @default(true)
  tenants     tenants    @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expenses    expenses[]
}

model expenses {
  id                                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  camp_id                           String             @db.Uuid
  category_id                       String             @db.Uuid
  amount                            Decimal            @db.Decimal(10, 2)
  description                       String
  expense_date                      DateTime           @db.Date
  month                             Int                @db.SmallInt
  year                              Int                @db.SmallInt
  payment_method                    String?            @db.VarChar(50)
  reference_number                  String?            @db.VarChar(255)
  receipt_url                       String?
  approved_by                       String?            @db.Uuid
  created_by                        String?            @db.Uuid
  created_at                        DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime?          @default(now()) @db.Timestamptz(6)
  users_expenses_approved_byTousers users?             @relation("expenses_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  camps                             camps              @relation(fields: [camp_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expense_categories                expense_categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_expenses_created_byTousers  users?             @relation("expenses_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model feature_flags {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String?   @db.Uuid
  flag_key    String    @db.VarChar(100)
  flag_name   String?   @db.VarChar(255)
  description String?
  is_enabled  Boolean?  @default(false)
  config      Json?     @default("{}")
  enabled_at  DateTime? @db.Timestamptz(6)
  enabled_by  String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users?    @relation(fields: [enabled_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants     tenants?  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenant_id, flag_key])
}

model individuals {
  id                         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                  String              @db.Uuid
  full_name                  String?             @db.VarChar(255)
  owner_name                 String              @db.VarChar(255)
  mobile_number              String?             @db.VarChar(50)
  nationality                String?             @db.VarChar(100)
  religion                   String?             @db.VarChar(100)
  languages                  String?             @db.VarChar(255)
  company_name               String?             @db.VarChar(255)
  profession                 String?             @db.VarChar(100)
  industry                   String?             @db.VarChar(100)
  id_type                    String?             @db.VarChar(50)
  id_number                  String?             @db.VarChar(100)
  id_copy_on_file            Boolean?            @default(false)
  is_active                  Boolean?            @default(true)
  notes                      String?
  created_at                 DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?           @default(now()) @db.Timestamptz(6)
  emergency_contact_name     String?             @db.VarChar(255)
  emergency_contact_phone    String?             @db.VarChar(50)
  emergency_contact_relation String?             @db.VarChar(50)
  emergency_contact_country  String?             @db.VarChar(100)
  balance_writeoffs          balance_writeoffs[]
  bed_occupancy              bed_occupancy[]
  contracts                  contracts[]
  tenants                    tenants             @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  monthly_records            monthly_records[]
  room_occupancy             room_occupancy[]
  security_deposits          security_deposits[]
}

model map_layouts {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  camp_id          String    @db.Uuid
  version          Int       @default(1)
  canvas_width     Decimal?  @default(1400) @db.Decimal(10, 2)
  canvas_height    Decimal?  @default(900) @db.Decimal(10, 2)
  background_color String?   @default("#07101f") @db.VarChar(20)
  scale_factor     Decimal?  @default(1.0) @db.Decimal(6, 4)
  north_direction  Int?      @default(0)
  is_active        Boolean?  @default(true)
  is_configured    Boolean?  @default(false)
  configured_at    DateTime? @db.Timestamptz(6)
  configured_by    String?   @db.Uuid
  notes            String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  camps            camps     @relation(fields: [camp_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            users?    @relation(fields: [configured_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([camp_id, version])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model monthly_records {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_id           String              @db.Uuid
  camp_id           String              @db.Uuid
  occupancy_id      String?             @db.Uuid
  month             Int                 @db.SmallInt
  year              Int                 @db.SmallInt
  individual_id     String?             @db.Uuid
  owner_name        String?             @db.VarChar(255)
  company_id        String?             @db.Uuid
  company_name      String?             @db.VarChar(255)
  contract_type     String?             @db.VarChar(30)
  contract_start_date DateTime?         @db.Date
  contract_end_date   DateTime?         @db.Date
  people_count      Int?                @default(0)
  rent              Decimal             @default(0) @db.Decimal(10, 2)
  paid              Decimal             @default(0) @db.Decimal(10, 2)
  balance           Decimal?            @default(dbgenerated("(rent - paid)")) @db.Decimal(10, 2)
  off_days          Int?                @default(0)
  remarks           String?
  is_locked         Boolean?            @default(false)
  created_by        String?             @db.Uuid
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  camps             camps               @relation(fields: [camp_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companies         companies?          @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  individuals       individuals?        @relation(fields: [individual_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  room_occupancy    room_occupancy?     @relation(fields: [occupancy_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms             rooms               @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment_schedules payment_schedules[]
  payments          payments[]

  @@unique([room_id, month, year])
  @@index([camp_id], map: "idx_monthly_camp")
  @@index([year, month], map: "idx_monthly_period")
  @@index([room_id], map: "idx_monthly_room")
}

model notifications {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  user_id       String?   @db.Uuid
  type          String    @db.VarChar(100)
  title         String    @db.VarChar(255)
  message       String?
  resource_type String?   @db.VarChar(100)
  resource_id   String?   @db.Uuid
  is_read       Boolean?  @default(false)
  read_at       DateTime? @db.Timestamptz(6)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  snoozed_until DateTime? @db.Timestamptz(6)
  tenants       tenants   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, is_read], map: "idx_notifications_user")
}

model payments {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  monthly_record_id String          @db.Uuid
  room_id           String          @db.Uuid
  camp_id           String          @db.Uuid
  amount            Decimal         @db.Decimal(10, 2)
  payment_method    String          @default("cash") @db.VarChar(50)
  payment_date      DateTime        @db.Date
  reference_number  String?         @db.VarChar(255)
  bank_name         String?         @db.VarChar(100)
  cheque_number     String?         @db.VarChar(100)
  notes             String?
  received_by       String?         @db.Uuid
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  camps             camps           @relation(fields: [camp_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  monthly_records   monthly_records @relation(fields: [monthly_record_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?          @relation(fields: [received_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms             rooms           @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([payment_date], map: "idx_payments_date")
  @@index([room_id], map: "idx_payments_room")
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource         String             @db.VarChar(100)
  action           String             @db.VarChar(50)
