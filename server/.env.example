# ============================================================
# Bartawi CMS — Backend Environment
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://bartawi:bartawi_dev_password@localhost:5432/bartawi_cms

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=24h

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Feature flags (overrides DB, useful for testing) ---
# FORCE_ENABLE_CONTRACT_ALERTS=false
# FORCE_ENABLE_IOT=false

# --- AI (optional) ---
# ANTHROPIC_API_KEY=

# --- Storage (future) ---
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET=bartawi-documents
